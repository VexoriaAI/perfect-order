@page "/billing-companies"
@attribute [Authorize(Roles = "Admin")]

@using Microsoft.AspNetCore.Authorization
@using Simulador.App.Modules.BillingCompanies.DTOs
@using Simulador.App.Shared

@rendermode InteractiveServer

@inject ApiClient Api

<h3>Cadastro de Empresas de Faturamento</h3>

@if (!_loaded)
{
    <div class="alert alert-info">Carregando...</div>
}
else
{
    <div class="row g-3">
        <div class="col-lg-4">
            <div class="card p-3">
                <h5>Nova empresa</h5>

                <div class="mb-2">
                    <label class="form-label">Código</label>
                    <input class="form-control" @bind="form.CompanyCode" />
                </div>

                <div class="mb-2">
                    <label class="form-label">Nome</label>
                    <input class="form-control" @bind="form.Name" />
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" @bind="form.IsActive" />
                    <label class="form-check-label">Ativa</label>
                </div>

                <button class="btn btn-primary w-100" @onclick="SaveAsync" disabled="@isBusy">
                    @(isBusy ? "Salvando..." : "Cadastrar")
                </button>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert alert-success mt-3">@message</div>
                }

                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="alert alert-danger mt-3">@error</div>
                }
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card p-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Empresas cadastradas</h5>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="LoadAsync" disabled="@isBusy">
                        Atualizar
                    </button>
                </div>

                @if (companies.Count == 0)
                {
                    <div class="alert alert-warning mb-0">Nenhuma empresa cadastrada.</div>
                }
                else
                {
                    <table class="table table-striped table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Display</th>
                                <th>Ativa</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in companies
                                        .OrderBy(x => int.TryParse(x.CompanyCode, out var n) ? n : int.MaxValue)
                                        .ThenBy(x => x.CompanyCode))
                            {
                                <tr>
                                    <td>@c.CompanyCode</td>
                                    <td>@c.DisplayName</td>
                                    <td>
                                        @if (c.IsActive)
                                        {
                                            <span class="badge bg-success">Sim</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Não</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _loaded;
    private bool isBusy;
    private string? error;
    private string? message;

    private List<BillingCompanyMini> companies = new();

    private BillingCompanyCreateDto form = new()
    {
        IsActive = true
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _loaded = true;
    }

    private async Task LoadAsync()
    {
        try
        {
            isBusy = true;
            error = null;
            message = null;

            companies = await Api.GetBillingCompaniesAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task SaveAsync()
    {
        try
        {
            isBusy = true;
            error = null;
            message = null;

            if (string.IsNullOrWhiteSpace(form.CompanyCode))
                throw new InvalidOperationException("Informe o código da empresa.");

            if (string.IsNullOrWhiteSpace(form.Name))
                throw new InvalidOperationException("Informe o nome da empresa.");

            var created = await Api.CreateBillingCompanyAsync(form);

            if (created is null)
                throw new InvalidOperationException("Não foi possível cadastrar a empresa.");

            message = "Empresa cadastrada com sucesso.";

            form = new BillingCompanyCreateDto
            {
                IsActive = true
            };

            companies = await Api.GetBillingCompaniesAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }
}