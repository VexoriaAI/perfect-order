@page "/customers"
@attribute [Authorize(Roles = "Admin")]

@using Microsoft.AspNetCore.Authorization
@using Simulador.App.Modules.Customers.Dtos
@using Simulador.App.Shared

@rendermode InteractiveServer

@inject ApiClient Api

<h3>Cadastro de Clientes</h3>

@if (!_loaded)
{
    <div class="alert alert-info">Carregando...</div>
}
else
{
    <div class="row g-3">
        <div class="col-lg-4">
            <div class="card p-3">
                <h5>Novo cliente</h5>

                <div class="mb-2">
                    <label class="form-label">Código</label>
                    <input class="form-control" @bind="form.CustomerCode" />
                </div>

                <div class="mb-2">
                    <label class="form-label">Nome</label>
                    <input class="form-control" @bind="form.Name" />
                </div>

                <div class="mb-2">
                    <label class="form-label">UF</label>
                    <input class="form-control" maxlength="2" @bind="form.Uf" />
                </div>

                <div class="mb-2">
                    <label class="form-label">Cidade</label>
                    <input class="form-control" @bind="form.City" />
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" @bind="form.IsActive" />
                    <label class="form-check-label">Ativo</label>
                </div>

                <hr />

                <h6>Regras</h6>

                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" @bind="form.Rules.AllowsBulk" />
                    <label class="form-check-label">Permite carga batida</label>
                </div>

                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" @bind="form.Rules.AllowsPalletized" />
                    <label class="form-check-label">Permite carga paletizada</label>
                </div>

                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" @bind="form.Rules.AllowsMix" />
                    <label class="form-check-label">Permite mix</label>
                </div>

                <div class="mb-2">
                    <label class="form-label">Máx. Kg por palete</label>
                    <input class="form-control" type="number" step="0.01" @bind="form.Rules.MaxKgPerPallet" />
                </div>

                <hr />

                <h6>Veículos autorizados</h6>

                @if (vehicles.Count == 0)
                {
                    <div class="text-muted small">Nenhum veículo carregado.</div>
                }
                else
                {
                    @foreach (var vehicle in vehicles.OrderBy(x => x.OrderIndex))
                    {
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   checked="@form.AllowedVehicles.Contains(vehicle.Name)"
                                   @onchange="e => ToggleVehicle(vehicle.Name, e.Value)" />
                            <label class="form-check-label">@vehicle.Name</label>
                        </div>
                    }
                }

                <button class="btn btn-primary w-100 mt-3" @onclick="SaveAsync" disabled="@isBusy">
                    @(isBusy ? "Salvando..." : "Cadastrar")
                </button>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert alert-success mt-3">@message</div>
                }

                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="alert alert-danger mt-3">@error</div>
                }
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card p-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Clientes cadastrados</h5>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="LoadAsync" disabled="@isBusy">
                        Atualizar
                    </button>
                </div>

                @if (customers.Count == 0)
                {
                    <div class="alert alert-warning mb-0">Nenhum cliente cadastrado.</div>
                }
                else
                {
                    <table class="table table-striped table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Código</th>
                                <th>Nome</th>
                                <th>UF</th>
                                <th>Cidade</th>
                                <th>Ativo</th>
                                <th>Regras</th>
                                <th>Veículos</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in PagedCustomers)
                            {
                                <tr>
                                    <td>@c.CustomerCode</td>
                                    <td>@c.Name</td>
                                    <td>@c.Uf</td>
                                    <td>@c.City</td>
                                    <td>@(c.IsActive ? "Sim" : "Não")</td>
                                    <td>
                                        <div class="small">
                                            Batida: @(c.Rules?.AllowsBulk == true ? "Sim" : "Não")<br />
                                            Paletizada: @(c.Rules?.AllowsPalletized == true ? "Sim" : "Não")<br />
                                            Mix: @(c.Rules?.AllowsMix == true ? "Sim" : "Não")<br />
                                            Kg/palete: @(c.Rules?.MaxKgPerPallet?.ToString() ?? "-")
                                        </div>
                                    </td>
                                    <td>
                                        <div class="small">
                                            @(c.AllowedVehicles.Count == 0
                                                ? "-"
                                                : string.Join(", ", c.AllowedVehicles))
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    @if (TotalPages > 1)
                    {
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <div class="text-muted">
                                Página @currentPage de @TotalPages
                            </div>

                            <div class="btn-group" role="group">
                                <button class="btn btn-outline-secondary btn-sm"
                                        @onclick="() => GoToPage(currentPage - 1)"
                                        disabled="@(currentPage == 1)">
                                    Anterior
                                </button>

                                @foreach (var pageNumber in PageNumbers)
                                {
                                    <button class="btn @(pageNumber == currentPage ? "btn-primary" : "btn-outline-primary") btn-sm"
                                            @onclick="() => GoToPage(pageNumber)">
                                        @pageNumber
                                    </button>
                                }

                                <button class="btn btn-outline-secondary btn-sm"
                                        @onclick="() => GoToPage(currentPage + 1)"
                                        disabled="@(currentPage == TotalPages)">
                                    Próxima
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _loaded;
    private bool isBusy;
    private string? error;
    private string? message;

    private List<CustomerDto> customers = new();
    private List<VehicleMini> vehicles = new();

    private CustomerCreateDto form = NewForm();

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _loaded = true;
    }

    private async Task LoadAsync()
    {
        isBusy = true;
        error = null;
        message = null;

        try
        {
            customers = await Api.GetCustomersAdminAsync();
            currentPage = 1;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }

        try
        {
            vehicles = await Api.GetVehiclesAsync();
        }
        catch (Exception ex)
        {
            error = string.IsNullOrWhiteSpace(error)
                ? ex.Message
                : $"{error} | {ex.Message}";
        }

        isBusy = false;
    }

    private async Task SaveAsync()
    {
        try
        {
            isBusy = true;
            error = null;
            message = null;

            if (string.IsNullOrWhiteSpace(form.CustomerCode))
                throw new InvalidOperationException("Informe o código do cliente.");

            if (string.IsNullOrWhiteSpace(form.Name))
                throw new InvalidOperationException("Informe o nome do cliente.");

            var created = await Api.CreateCustomerAsync(form);

            if (created is null)
                throw new InvalidOperationException("Não foi possível cadastrar o cliente.");

            message = "Cliente cadastrado com sucesso.";
            form = NewForm();

            customers = await Api.GetCustomersAdminAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private void ToggleVehicle(string vehicleName, object? value)
    {
        var isChecked = value is bool b && b;

        if (isChecked)
        {
            if (!form.AllowedVehicles.Contains(vehicleName, StringComparer.OrdinalIgnoreCase))
                form.AllowedVehicles.Add(vehicleName);
        }
        else
        {
            form.AllowedVehicles.RemoveAll(x =>
                string.Equals(x, vehicleName, StringComparison.OrdinalIgnoreCase));
        }
    }

    private static CustomerCreateDto NewForm() => new()
    {
        IsActive = true,
        Rules = new CustomerRulesDto
        {
            AllowsBulk = true,
            AllowsPalletized = true,
            AllowsMix = true
        },
        AllowedVehicles = new List<string>()
    };
    private const int PageSize = 10;
    private int currentPage = 1;

    private int TotalPages =>
        customers.Count == 0 ? 1 : (int)Math.Ceiling(customers.Count / (double)PageSize);

    private List<CustomerDto> PagedCustomers =>
        customers.OrderBy(x => x.CustomerCode)
            .Skip((currentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList();

    private IEnumerable<int> PageNumbers =>
        Enumerable.Range(1, TotalPages);

    private void GoToPage(int page)
    {
        if (page < 1 || page > TotalPages)
            return;

        currentPage = page;
    }
}