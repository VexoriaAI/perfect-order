@page "/price-averages"
@attribute [Authorize(Roles = "Admin")]

@using Microsoft.AspNetCore.Authorization
@using Simulador.App.Modules.BillingCompanies.DTOs
@using Simulador.App.Modules.Catalog.Dtos
@using Simulador.App.Shared

@rendermode InteractiveServer

@inject ApiClient Api

<h3>Cadastro de Preços Médios</h3>

@if (!_loaded)
{
    <div class="alert alert-info">Carregando...</div>
}
else
{
    <div class="row g-3">
        <div class="col-lg-4">
            <div class="card p-3">
                <h5>Novo preço médio</h5>

                <div class="mb-2">
                    <label class="form-label">Empresa de faturamento</label>
                    <select class="form-select" @bind="form.CompanyBilling">
                        <option value="">-- selecione --</option>
                        @foreach (var c in billingCompanies
                            .Where(x => x.IsActive)
                            .OrderBy(x => int.TryParse(x.CompanyCode, out var n) ? n : int.MaxValue)
                            .ThenBy(x => x.DisplayName))
                        {
                            <option value="@c.DisplayName">@c.DisplayName</option>
                        }
                    </select>
                </div>

                <div class="mb-2">
                    <label class="form-label">Produto</label>
                    <select class="form-select" @bind="form.Sku">
                        <option value="">-- selecione --</option>
                        @foreach (var p in products.Where(x => x.IsActive).OrderBy(x => x.InternalCode))
                        {
                            <option value="@p.Sku">@p.DisplayLabel</option>
                        }
                    </select>
                </div>

                <div class="mb-2">
                    <label class="form-label">Preço médio</label>
                    <input class="form-control" type="number" step="0.01" @bind="form.AvgUnitPrice" />
                </div>

                <button class="btn btn-primary w-100 mt-2" @onclick="SaveAsync" disabled="@isBusy">
                    @(isBusy ? "Salvando..." : "Salvar")
                </button>

                @if (!string.IsNullOrWhiteSpace(message))
                {
                    <div class="alert alert-success mt-3">@message</div>
                }

                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="alert alert-danger mt-3">@error</div>
                }
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card p-3">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Preços cadastrados</h5>
                    <button class="btn btn-outline-secondary btn-sm" @onclick="LoadAsync" disabled="@isBusy">
                        Atualizar
                    </button>
                </div>

                @if (prices.Count == 0)
                {
                    <div class="alert alert-warning mb-0">Nenhum preço médio cadastrado.</div>
                }
                else
                {
                    <table class="table table-striped table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Empresa</th>
                                <th>SKU</th>
                                <th>Preço médio</th>
                                <th>Atualizado em</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in PagedPrices)
                            {
                                <tr>
                                    <td>@item.CompanyBilling</td>
                                    <td>@item.Sku</td>
                                    <td>@item.AvgUnitPrice</td>
                                    <td>@item.UpdatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    @if (TotalPages > 1)
                    {
                        <div class="d-flex justify-content-between align-items-center mt-3">
                            <div class="text-muted">
                                Página @currentPage de @TotalPages
                            </div>

                            <div class="btn-group" role="group">
                                <button class="btn btn-outline-secondary btn-sm"
                                        @onclick="() => GoToPage(currentPage - 1)"
                                        disabled="@(currentPage == 1)">
                                    Anterior
                                </button>

                                @foreach (var pageNumber in PageNumbers)
                                {
                                    <button class="btn @(pageNumber == currentPage ? "btn-primary" : "btn-outline-primary") btn-sm"
                                            @onclick="() => GoToPage(pageNumber)">
                                        @pageNumber
                                    </button>
                                }

                                <button class="btn btn-outline-secondary btn-sm"
                                        @onclick="() => GoToPage(currentPage + 1)"
                                        disabled="@(currentPage == TotalPages)">
                                    Próxima
                                </button>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
}

@code {
    private bool _loaded;
    private bool isBusy;
    private string? error;
    private string? message;

    private List<BillingCompanyMini> billingCompanies = new();
    private List<ProductMini> products = new();
    private List<PriceAverageDto> prices = new();

    private PriceAverageUpsertDto form = NewForm();

    private const int PageSize = 10;
    private int currentPage = 1;

    private int TotalPages =>
        prices.Count == 0 ? 1 : (int)Math.Ceiling(prices.Count / (double)PageSize);

    private List<PriceAverageDto> PagedPrices =>
        prices.OrderBy(x => x.CompanyBilling)
            .ThenBy(x => x.Sku)
            .Skip((currentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList();

    private IEnumerable<int> PageNumbers =>
        Enumerable.Range(1, TotalPages);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _loaded = true;
    }

    private async Task LoadAsync()
    {
        try
        {
            isBusy = true;
            error = null;
            message = null;

            billingCompanies = await Api.GetBillingCompaniesAsync();
            products = await Api.GetProductsAsync();
            prices = await Api.GetPriceAveragesAsync();
            currentPage = 1;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task SaveAsync()
    {
        try
        {
            isBusy = true;
            error = null;
            message = null;

            if (string.IsNullOrWhiteSpace(form.CompanyBilling))
                throw new InvalidOperationException("Selecione a empresa.");

            if (string.IsNullOrWhiteSpace(form.Sku))
                throw new InvalidOperationException("Selecione o produto.");

            if (form.AvgUnitPrice <= 0)
                throw new InvalidOperationException("Informe um preço médio maior que zero.");

            var saved = await Api.UpsertPriceAverageAsync(form);

            if (saved is null)
                throw new InvalidOperationException("Não foi possível salvar o preço médio.");

            message = "Preço médio salvo com sucesso.";
            form = NewForm();

            prices = await Api.GetPriceAveragesAsync();
            currentPage = 1;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private void GoToPage(int page)
    {
        if (page < 1 || page > TotalPages)
            return;

        currentPage = page;
    }

    private static PriceAverageUpsertDto NewForm() => new()
    {
        AvgUnitPrice = 0
    };
}