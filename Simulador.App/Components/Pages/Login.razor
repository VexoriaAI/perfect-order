@page "/"
@page "/login"
@attribute [AllowAnonymous]
@rendermode InteractiveServer

@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Authorization
@using Microsoft.JSInterop

@inject IJSRuntime JS
@inject NavigationManager Nav

<h3>Login</h3>

<EditForm Model="model" OnValidSubmit="DoLogin" FormName="login-form">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="card p-3" style="max-width:480px;">
        <div class="mb-2">
            <label class="form-label">E-mail</label>
            <InputText class="form-control" @bind-Value="model.Email" />
        </div>

        <div class="mb-2">
            <label class="form-label">Senha</label>
            <InputText class="form-control" type="password" @bind-Value="model.Password" />
        </div>

        <div class="form-check mb-3">
            <InputCheckbox class="form-check-input" @bind-Value="model.RememberMe" />
            <label class="form-check-label">Lembrar login</label>
        </div>

        <button type="submit" class="btn btn-primary" disabled="@isBusy">
            @(isBusy ? "Entrando..." : "Entrar")
        </button>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger mt-3">@error</div>
        }
    </div>
</EditForm>

@code {
    private readonly LoginVm model = new();
    private bool isBusy;
    private string? error;

    private async Task DoLogin()
    {
        error = null;
        isBusy = true;

        try
        {
            await JS.InvokeAsync<object>("simuladorAuth.login", new
            {
                email = model.Email,
                password = model.Password,
                rememberMe = model.RememberMe
            });

            Nav.NavigateTo("simulator", forceLoad: true);
        }
        catch (JSException ex)
        {
            error = ex.Message;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private sealed class LoginVm
    {
        [Required(ErrorMessage = "Informe o e-mail.")]
        [EmailAddress(ErrorMessage = "E-mail inválido.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Informe a senha.")]
        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }
}