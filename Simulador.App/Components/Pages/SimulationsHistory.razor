@page "/history"
@attribute [Authorize]

@using System.Text.Json
@using Microsoft.AspNetCore.Authorization
@using Simulador.App.Modules.Simulations.Dtos
@using Simulador.App.Shared
@using Simulador.Engine.Contracts

@rendermode InteractiveServer

@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3>Histórico de Simulações</h3>

@if (!_loaded)
{
    <div class="alert alert-info">Carregando...</div>
}
else
{
    <div class="card p-3 mb-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0">Simulações realizadas</h5>
            <button class="btn btn-outline-secondary btn-sm" @onclick="LoadAsync" disabled="@isBusy">
                Atualizar
            </button>
        </div>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="alert alert-danger">@error</div>
        }

        @if (rows.Count == 0)
        {
            <div class="alert alert-warning mb-0">Nenhuma simulação encontrada.</div>
        }
        else
        {
            <table class="table table-striped table-sm align-middle">
                <thead>
                    <tr>
                        <th>Número</th>
                        <th>Data</th>
                        <th>Empresa</th>
                        <th>Estado</th>
                        <th>Cidade</th>
                        <th>Itens</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var row in PagedRows)
                    {
                        <tr>
                            <td>@row.RunId</td>
                            <td>@row.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                            <td>@row.CompanyBilling</td>
                            <td>@row.StateCode</td>
                            <td>@row.CityName</td>
                            <td>@row.ItemCount</td>
                            <td>
                                <button class="btn btn-sm btn-primary"
                                        @onclick="() => LoadDetailAsync(row.RunId)"
                                        disabled="@isBusy">
                                    Ver
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            @if (TotalPages > 1)
            {
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">
                        Página @currentPage de @TotalPages
                    </div>

                    <div class="btn-group" role="group">
                        <button class="btn btn-outline-secondary btn-sm"
                                @onclick="() => GoToPage(currentPage - 1)"
                                disabled="@(currentPage == 1)">
                            Anterior
                        </button>

                        @foreach (var pageNumber in PageNumbers)
                        {
                            <button class="btn @(pageNumber == currentPage ? "btn-primary" : "btn-outline-primary") btn-sm"
                                    @onclick="() => GoToPage(pageNumber)">
                                @pageNumber
                            </button>
                        }

                        <button class="btn btn-outline-secondary btn-sm"
                                @onclick="() => GoToPage(currentPage + 1)"
                                disabled="@(currentPage == TotalPages)">
                            Próxima
                        </button>
                    </div>
                </div>
            }
        }
    </div>

    @if (detail is not null)
    {
        <div class="card p-3">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Detalhe da Simulação</h5>
                <button class="btn btn-outline-secondary btn-sm" @onclick="ClearDetail">
                    Fechar
                </button>
            </div>

            <div class="row g-2 mb-3">
                <div class="col-md-4">
                    <div class="border rounded p-2">
                        <strong>Número:</strong><br />
                        @detail.RunId
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border rounded p-2">
                        <strong>Data:</strong><br />
                        @detail.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border rounded p-2">
                        <strong>Empresa:</strong><br />
                        @detail.CompanyBilling
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border rounded p-2">
                        <strong>Vendedor?</strong><br />
                        @(detail.IsSeller ? "Sim" : "Não")
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border rounded p-2">
                        <strong>Estado:</strong><br />
                        @detail.StateCode
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="border rounded p-2">
                        <strong>Cidade:</strong><br />
                        @detail.CityName
                    </div>
                </div>
            </div>

            @if (ParsedRequest is not null)
            {
                <div class="mt-4">
                    <h5>Requisição</h5>

                    <div class="row g-2 mb-3">
                        <div class="col-md-4">
                            <div class="border rounded p-2">
                                <strong>Cliente</strong><br />
                                @ParsedRequest.CustomerCode
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="border rounded p-2">
                                <strong>Empresa</strong><br />
                                @ParsedRequest.CompanyBilling
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="border rounded p-2">
                                <strong>Tipo de carga</strong><br />
                                @(ParsedRequest.IsPalletized ? "Paletizada" : "Batida")
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="border rounded p-2">
                                <strong>Usuário vendedor</strong><br />
                                @(ParsedRequest.IsSeller ? "Sim" : "Não")
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="border rounded p-2">
                                <strong>Shipment Type</strong><br />
                                @ParsedRequest.ShipmentType
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="border rounded p-2">
                                <strong>Perda</strong><br />
                                @(ParsedRequest.Loss?.LossPercent?.ToString() ?? "-")
                            </div>
                        </div>
                    </div>

                    <h6>Itens da requisição</h6>

                    @if (ParsedRequest.Items?.Count > 0)
                    {
                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <th>SKU</th>
                                    <th>Qtd</th>
                                    <th>Preço unit.</th>
                                    <th>Unid./Palete</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in ParsedRequest.Items)
                                {
                                    <tr>
                                        <td>@item.Sku</td>
                                        <td>@item.Quantity</td>
                                        <td>@item.UnitPrice</td>
                                        <td>@item.PalletUnitsOverride</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="alert alert-warning">Nenhum item encontrado na requisição.</div>
                    }
                </div>
            }

            @if (ParsedResult is not null)
            {
                <div class="mt-4">
                    <h5>Resposta</h5>

                    <div class="row g-2 mb-3">
                        <div class="col-md-3">
                            <div class="border rounded p-2">
                                <strong>Peso</strong><br />
                                @ParsedResult.Totals.WeightKg
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="border rounded p-2">
                                <strong>Cubagem</strong><br />
                                @ParsedResult.Totals.VolumeM3
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="border rounded p-2">
                                <strong>Paletes</strong><br />
                                @ParsedResult.Totals.Pallets
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="border rounded p-2">
                                <strong>Valor itens</strong><br />
                                @ParsedResult.Totals.ItemsValue
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="border rounded p-2">
                                <strong>Perda aplicada</strong><br />
                                @ParsedResult.Loss.AppliedPercent
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="border rounded p-2">
                                <strong>Cubagem efetiva</strong><br />
                                @ParsedResult.Loss.EffectiveVolumeM3
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="border rounded p-2">
                                <strong>Veículo recomendado</strong><br />
                                @(ParsedResult.Vehicle.Recommended ?? "N/A")
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-2">
                                <strong>Motivo</strong><br />
                                @(ParsedResult.Vehicle.Reason ?? "-")
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="border rounded p-2">
                                <strong>Observação de capacidade</strong><br />
                                @(ParsedResult.Vehicle.CapacityWarning ?? "-")
                            </div>
                        </div>
                    </div>

                    @if (ParsedResult.Warnings?.Count > 0)
                    {
                        <div class="alert alert-warning">
                            <strong>Warnings:</strong> @string.Join(", ", ParsedResult.Warnings)
                        </div>
                    }

                    <h6>Itens da resposta</h6>

                    @if (ParsedResult.Items?.Count > 0)
                    {
                        <table class="table table-sm table-striped">
                            <thead>
                                <tr>
                                    <th>Cód. interno</th>
                                    <th>SKU</th>
                                    <th>Descrição</th>
                                    <th>Qtd</th>
                                    <th>Preço aplicado</th>
                                    <th>Peso</th>
                                    <th>Cubagem</th>
                                    <th>Paletes</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in ParsedResult.Items)
                                {
                                    <tr>
                                        <td>@item.InternalCode</td>
                                        <td>@item.Sku</td>
                                        <td>@item.Description</td>
                                        <td>@item.Quantity</td>
                                        <td>@item.UnitPriceApplied</td>
                                        <td>@item.WeightKg</td>
                                        <td>@item.VolumeM3</td>
                                        <td>@item.PalletsFinal</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                    else
                    {
                        <div class="alert alert-warning">Nenhum item encontrado na resposta.</div>
                    }
                </div>
            }

            <div class="mt-4">
                <details>
                    <summary class="fw-semibold">Request JSON bruto</summary>
                    <pre class="bg-light border rounded p-3 mt-2 small" style="white-space: pre-wrap; overflow-x: auto;">@FormatJson(detail.RequestJson)</pre>
                </details>
            </div>

            <div class="mt-3">
                <details>
                    <summary class="fw-semibold">Result JSON bruto</summary>
                    <pre class="bg-light border rounded p-3 mt-2 small" style="white-space: pre-wrap; overflow-x: auto;">@FormatJson(detail.ResultJson)</pre>
                </details>
            </div>
        </div>
    }
}

@code {
    private bool _loaded;
    private bool isBusy;
    private string? error;

    private List<SimulationHistoryRowDto> rows = new();
    private SimulationHistoryDetailDto? detail;

    private const int PageSize = 10;
    private int currentPage = 1;

    private int TotalPages =>
        rows.Count == 0 ? 1 : (int)Math.Ceiling(rows.Count / (double)PageSize);

    private List<SimulationHistoryRowDto> PagedRows =>
        rows.OrderByDescending(x => x.CreatedAt)
            .Skip((currentPage - 1) * PageSize)
            .Take(PageSize)
            .ToList();

    private IEnumerable<int> PageNumbers =>
        Enumerable.Range(1, TotalPages);

    private SimulationRequest? ParsedRequest =>
        DeserializeJson<SimulationRequest>(detail?.RequestJson);

    private SimulationResult? ParsedResult =>
        DeserializeJson<SimulationResult>(detail?.ResultJson);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        _loaded = true;
    }

    private void GoToPage(int page)
    {
        if (page < 1 || page > TotalPages)
            return;

        currentPage = page;
    }

    private async Task LoadAsync()
    {
        try
        {
            isBusy = true;
            error = null;

            rows = await Api.GetSimulationHistoryAsync();
            currentPage = 1;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task LoadDetailAsync(Guid runId)
    {
        try
        {
            isBusy = true;
            error = null;

            detail = await Api.GetSimulationHistoryDetailAsync(runId);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private void ClearDetail()
    {
        detail = null;
    }

    private static T? DeserializeJson<T>(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return default;

        try
        {
            return JsonSerializer.Deserialize<T>(json, new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });
        }
        catch
        {
            return default;
        }
    }

    private string FormatJson(string? json)
    {
        if (string.IsNullOrWhiteSpace(json))
            return string.Empty;

        try
        {
            using var doc = JsonDocument.Parse(json);

            return JsonSerializer.Serialize(doc.RootElement, new JsonSerializerOptions
            {
                WriteIndented = true
            });
        }
        catch
        {
            return json;
        }
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("simuladorAuth.logout");
        Nav.NavigateTo("login", true);
    }
}