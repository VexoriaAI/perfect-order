@page "/simulator"
@using Simulador.App.Shared
@using Simulador.Engine.Contracts
@rendermode InteractiveServer
@inject AppState State
@inject ApiClient Api
@inject NavigationManager Nav

<h3>Simulador</h3>

@if (!_loaded)
{
    <div class="alert alert-info">Carregando...</div>
}
else if (!State.IsLoggedIn)
{
    <div class="alert alert-warning">
        Você precisa fazer login. <a href="/login">Ir para Login</a>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div>
            <strong>@(State.DisplayName ?? "Usuário")</strong> —
            Perfil: <span class="badge bg-secondary">@State.Role</span>
        </div>
        <button type="button" class="btn btn-outline-danger btn-sm" @onclick="Logout">Sair</button>
    </div>

    <div class="row g-3">
        <div class="col-lg-4">
            <div class="card p-3">
                <h5>Pedido</h5>

                <div class="mb-2">
                    <label class="form-label">Cliente</label>
                    <select class="form-select" @bind="request.CustomerCode">
                        <option value="">-- selecione --</option>
                        @foreach (var c in customers.Where(x => x.IsActive))
                        {
                            <option value="@c.CustomerCode">@c.CustomerCode - @c.Name</option>
                        }
                    </select>
                </div>

                <div class="mb-2">
                    <label class="form-label">Empresa Faturamento</label>
                    <input class="form-control" @bind="request.CompanyBilling" />
                </div>

                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" @bind="request.IsPalletized" />
                    <label class="form-check-label">Carga paletizada</label>
                </div>

                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" @bind="request.IsSeller" disabled />
                    <label class="form-check-label">Usuário vendedor</label>
                </div>

                @if (!request.IsPalletized)
                {
                    <div class="mb-2">
                        <label class="form-label">Perda cubagem (%)</label>
                        <input class="form-control" type="number" step="0.01" @bind="lossPercentUi" />
                        <small class="text-muted">Ex: 0.10 = 10%</small>
                    </div>
                }

                <div class="mb-2">
                    <label class="form-label">Frete ideal (%)</label>
                    <input class="form-control" type="number" step="0.01" @bind="idealFreightUi" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Frete aceitável (%)</label>
                    <input class="form-control" type="number" step="0.01" @bind="acceptableFreightUi" />
                </div>

                <button type="button" class="btn btn-primary w-100" @onclick="RunSimulation" disabled="@isBusy">
                    @(isBusy ? "Simulando..." : "Simular")
                </button>

                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="alert alert-danger mt-2">@error</div>
                }
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card p-3 mb-3">
                <h5>Itens</h5>

                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th style="width: 20%;">SKU</th>
                            <th style="width: 15%;">Qtd</th>
                            <th style="width: 20%;">Sug. unid/palete</th>
                            <th style="width: 20%;">Valor unit.</th>
                            <th style="width: 10%;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in request.Items)
                        {
                            <tr @key="item">
                                <td><input class="form-control form-control-sm" @bind="item.Sku" /></td>
                                <td><input class="form-control form-control-sm" type="number" @bind="item.Quantity" /></td>
                                <td><input class="form-control form-control-sm" type="number" @bind="item.PalletUnitsOverride" /></td>
                                <td><input class="form-control form-control-sm" type="number" step="0.01" @bind="item.UnitPrice" /></td>
                                <td>
                                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => RemoveItem(item)">X</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <button type="button" class="btn btn-outline-primary btn-sm" @onclick="AddItem">+ Adicionar item</button>
            </div>

            @if (result is not null)
            {
                <div class="card p-3">
                    <h5>Resultado</h5>

                    <div class="row g-2">
                        <div class="col-md-3"><div class="border rounded p-2">Peso: <b>@result.Totals.WeightKg</b> kg</div></div>
                        <div class="col-md-3"><div class="border rounded p-2">Cubagem: <b>@result.Totals.VolumeM3</b> m³</div></div>
                        <div class="col-md-3"><div class="border rounded p-2">Paletes: <b>@result.Totals.Pallets</b></div></div>
                        <div class="col-md-3"><div class="border rounded p-2">Valor: <b>@result.Totals.ItemsValue</b></div></div>
                    </div>

                    <div class="mt-2">
                        Perda aplicada: <b>@result.Loss.AppliedPercent</b> | Cubagem efetiva: <b>@result.Loss.EffectiveVolumeM3</b>
                    </div>

                    <div class="mt-2">
                        Frete ideal: <b>@result.Freight.IdealValue</b> | Frete aceitável: <b>@result.Freight.AcceptableValue</b>
                    </div>

                    <div class="mt-2">
                        Veículo: <b>@(result.Vehicle.Recommended ?? "N/A")</b>
                        @if (!string.IsNullOrWhiteSpace(result.Vehicle.CapacityWarning))
                        {
                            <span class="text-danger"> — @result.Vehicle.CapacityWarning</span>
                        }
                        <div class="text-muted">@result.Vehicle.Reason</div>
                    </div>

                    @if (result.Warnings?.Count > 0)
                    {
                        <div class="alert alert-warning mt-2">
                            @string.Join(", ", result.Warnings)
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private bool _loaded;

    private List<CustomerMini> customers = new();
    private SimulationRequest request = new()
    {
        ShipmentType = "Dedicated",
        Loss = new LossSettings { Mode = "Simple" },
        Freight = new FreightSettings(),
        Items = new List<SimulationItemRequest> { new() { Sku = "SKU001", Quantity = 1, UnitPrice = 1.0m } }
    };

    private decimal lossPercentUi = 0.10m;
    private decimal idealFreightUi = 0.06m;
    private decimal acceptableFreightUi = 0.08m;

    private bool isBusy;
    private string? error;
    private SimulationResult? result;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _loaded) return;
        _loaded = true;

        await State.LoadAsync(); // JS interop OK aqui

        if (!State.IsLoggedIn)
        {
            Nav.NavigateTo("/login", true);
            return;
        }

        request.IsSeller = State.IsSeller;

        customers = await Api.GetCustomersAsync();

        var cfg = await Api.GetConfigAsync();
        if (cfg is not null)
        {
            lossPercentUi = cfg.DefaultLossPercent;
            idealFreightUi = cfg.FreightIdealPercent;
            acceptableFreightUi = cfg.FreightAcceptablePercent;
        }

        StateHasChanged();
    }

    private void AddItem()
        => request.Items.Add(new SimulationItemRequest { Sku = "", Quantity = 1, UnitPrice = State.IsSeller ? 1.0m : null });

    private void RemoveItem(SimulationItemRequest item)
    {
        request.Items.Remove(item);
    }

    private async Task RunSimulation()
    {
        error = null;
        result = null;
        isBusy = true;

        try
        {
            request.Loss.LossPercent = request.IsPalletized ? null : lossPercentUi;
            request.Freight.IdealPercent = idealFreightUi;
            request.Freight.AcceptablePercent = acceptableFreightUi;

            if (request.IsSeller)
            {
                foreach (var i in request.Items)
                    if (i.UnitPrice is null) i.UnitPrice = 0m;
            }

            var apiRes = await Api.SimulateAsync(request);
            result = apiRes?.Result;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task Logout()
    {
        await State.LogoutAsync();
        Nav.NavigateTo("/login", true);
    }
}