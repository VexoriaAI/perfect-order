@page "/simulator"
@attribute [Authorize]

@using System.Security.Claims
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.JSInterop
@using Simulador.App.Auth
@using Simulador.App.Modules.BillingCompanies.DTOs
@using Simulador.App.Modules.Regional.DTO
@using Simulador.App.Shared
@using Simulador.Engine.Contracts

@rendermode InteractiveServer

@inject AuthenticationStateProvider AuthStateProvider
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<h3>Simulador</h3>

@if (!_loaded)
{
    <div class="alert alert-info">Carregando...</div>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-2">
        <div>
            <strong>@(displayName ?? "Usuário")</strong> —
            Perfil:
            @if (isAdmin)
            {
                <span class="badge bg-danger">Admin</span>
            }
            else if (isSeller)
            {
                <span class="badge bg-secondary">Vendedor</span>
            }
        </div>

        <button type="button" class="btn btn-outline-danger btn-sm" @onclick="Logout">
            Sair
        </button>
    </div>

    <div class="row g-3">
        <div class="col-lg-4">
            <div class="card p-3">
                <h5>Pedido</h5>

                <div class="mb-2">
                    <label class="form-label">Cliente</label>
                    <select class="form-select" @bind="request.CustomerCode">
                        <option value="">-- selecione --</option>
                        @foreach (var c in customers.Where(x => x.IsActive).OrderBy(x => x.CustomerCode))
                        {
                            <option value="@c.CustomerCode">@c.CustomerCode - @c.Name</option>
                        }
                    </select>
                </div>

                <div class="mb-2">
                    <label class="form-label">Empresa Faturamento</label>
                    <select class="form-select" @bind="request.CompanyBilling">
                        <option value="">-- selecione --</option>
                        @foreach (var c in billingCompanies.Where(x => x.IsActive).OrderBy(x => x.DisplayName))
                        {
                            <option value="@c.DisplayName">@c.DisplayName</option>
                        }
                    </select>
                </div>

                <div class="form-check mb-2">
                    <input class="form-check-input" type="checkbox" @bind="request.IsPalletized" />
                    <label class="form-check-label">Carga paletizada</label>
                </div>

                <div class="form-check mb-2">
                    <input class="form-check-input"
                           type="checkbox"
                           checked="@request.IsSeller"
                           @onchange="OnSellerModeChanged"
                           disabled="@sellerModeLocked" />
                    <label class="form-check-label">Usuário vendedor</label>
                </div>

                @if (request.IsSeller)
                {
                    @if (isSeller && !isAdmin)
                    {
                        <div class="mb-2">
                            <label class="form-label">Vendedor</label>
                            <input class="form-control" value="@sellerDisplayName" disabled />
                        </div>
                    }
                    else
                    {
                        <div class="mb-2">
                            <label class="form-label">Vendedor</label>
                            <select class="form-select" value="@sellerIdUi" @onchange="OnSellerChanged">
                                <option value="">-- selecione --</option>
                                @foreach (var s in sellers.OrderBy(x => x.Name))
                                {
                                    <option value="@s.Id">@s.Name</option>
                                }
                            </select>
                        </div>
                    }
                }

                <div class="mb-2">
                    <label class="form-label">Regional</label>
                    <select class="form-select" value="@regionalIdUi" @onchange="OnRegionalChanged">
                        <option value="">-- selecione --</option>
                        @foreach (var r in regionals.OrderBy(x => x.Name))
                        {
                            <option value="@r.Id">@r.Code - @r.Name</option>
                        }
                    </select>
                </div>

                <div class="mb-2">
                    <label class="form-label">Estado</label>
                    <input class="form-control" maxlength="2" @bind="request.StateCode" />
                </div>

                <div class="mb-2">
                    <label class="form-label">Cidade</label>
                    <input class="form-control" @bind="request.CityName" />
                </div>

                @if (!request.IsPalletized)
                {
                    <div class="mb-2">
                        <label class="form-label">Perda cubagem (%)</label>
                        <input class="form-control" type="number" step="0.01" @bind="lossPercentUi" />
                        <small class="text-muted">Ex: 0.10 = 10%</small>
                    </div>
                }

                <button type="button" class="btn btn-primary w-100" @onclick="RunSimulation" disabled="@isBusy">
                    @(isBusy ? "Simulando..." : "Simular")
                </button>

                @if (!string.IsNullOrWhiteSpace(error))
                {
                    <div class="alert alert-danger mt-2">@error</div>
                }
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card p-3 mb-3">
                <h5>Itens</h5>

                <table class="table table-sm align-middle">
                    <thead>
                        <tr>
                            <th style="width: 40%;">Produto</th>
                            <th style="width: 15%;">Qtd</th>
                            <th style="width: 20%;">Sug. unid/palete</th>
                            <th style="width: 15%;">Valor unit.</th>
                            <th style="width: 10%;"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in request.Items)
                        {
                            <tr @key="item">
                                <td>
                                    <select class="form-select form-select-sm" @bind="item.Sku">
                                        <option value="">-- selecione --</option>
                                        @foreach (var p in products.Where(x => x.IsActive).OrderBy(x => x.InternalCode))
                                        {
                                            <option value="@p.Sku">@p.DisplayLabel</option>
                                        }
                                    </select>
                                </td>
                                <td>
                                    <input class="form-control form-control-sm" type="number" min="1" @bind="item.Quantity" />
                                </td>
                                <td>
                                    <input class="form-control form-control-sm" type="number" min="1" @bind="item.PalletUnitsOverride" />
                                </td>
                                <td>
                                    <input class="form-control form-control-sm"
                                           type="number"
                                           step="0.01"
                                           @bind="item.UnitPrice"
                                           disabled="@(!request.IsSeller)" />
                                </td>
                                <td>
                                    <button type="button" class="btn btn-outline-danger btn-sm" @onclick="() => RemoveItem(item)">X</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

                <button type="button" class="btn btn-outline-primary btn-sm" @onclick="AddItem">+ Adicionar item</button>
            </div>

            @if (result is not null)
            {
                <div class="card p-3">
                    <h5>Resultado</h5>

                    <div class="row g-2">
                        <div class="col-md-3"><div class="border rounded p-2">Peso: <b>@result.Totals.WeightKg</b> kg</div></div>
                        <div class="col-md-3"><div class="border rounded p-2">Cubagem: <b>@result.Totals.VolumeM3</b> m³</div></div>
                        <div class="col-md-3"><div class="border rounded p-2">Paletes: <b>@result.Totals.Pallets</b></div></div>
                        <div class="col-md-3"><div class="border rounded p-2">Valor: <b>@result.Totals.ItemsValue</b></div></div>
                    </div>

                    <div class="mt-2">
                        Perda aplicada: <b>@result.Loss.AppliedPercent</b> |
                        Cubagem efetiva: <b>@result.Loss.EffectiveVolumeM3</b>
                    </div>

                    <div class="mt-2">
                        Veículo: <b>@(result.Vehicle.Recommended ?? "N/A")</b>
                        @if (!string.IsNullOrWhiteSpace(result.Vehicle.CapacityWarning))
                        {
                            <span class="text-danger"> — @result.Vehicle.CapacityWarning</span>
                        }
                        <div class="text-muted">@result.Vehicle.Reason</div>
                    </div>

                    <div class="mt-2">
                        <strong>Status do frete:</strong> @result.Freight.Status
                    </div>

                    @if (result.Warnings?.Count > 0)
                    {
                        <div class="alert alert-warning mt-2">
                            @string.Join(", ", result.Warnings)
                        </div>
                    }

                    @if (result.Items?.Count > 0)
                    {
                        <div class="mt-3">
                            <h6>Itens simulados</h6>
                            <table class="table table-sm table-striped">
                                <thead>
                                    <tr>
                                        <th>Cód. interno</th>
                                        <th>SKU</th>
                                        <th>Descrição</th>
                                        <th>Qtd</th>
                                        <th>Peso</th>
                                        <th>Cubagem</th>
                                        <th>Paletes</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var i in result.Items)
                                    {
                                        <tr>
                                            <td>@i.InternalCode</td>
                                            <td>@i.Sku</td>
                                            <td>@i.Description</td>
                                            <td>@i.Quantity</td>
                                            <td>@i.WeightKg</td>
                                            <td>@i.VolumeM3</td>
                                            <td>@i.PalletsBase</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
}

@code {
    private bool _loaded;
    private bool isBusy;
    private string? error;
    private string? displayName;
    private string? sellerDisplayName;
    private bool isAdmin;
    private bool isSeller;

    private bool sellerModeLocked => isSeller && !isAdmin;

    private List<CustomerMini> customers = new();
    private List<BillingCompanyMini> billingCompanies = new();
    private List<ProductMini> products = new();
    private List<SellerMini> sellers = new();
    private List<RegionalMini> regionals = new();

    private string? sellerIdUi;
    private string? regionalIdUi;

    private SimulationRequest request = new()
    {
        ShipmentType = "Dedicated",
        Loss = new LossSettings { Mode = "Simple" },
        Freight = new FreightSettings(),
        Items = new List<SimulationItemRequest>
        {
            new() { Quantity = 1 }
        }
    };

    private decimal lossPercentUi = 0.10m;

    // Mantidos por compatibilidade com o backend atual,
    // mas não expostos na tela.
    private decimal idealFreightUi = 0.06m;
    private decimal acceptableFreightUi = 0.08m;

    private SimulationResult? result;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = auth.User;

            billingCompanies = await Api.GetBillingCompaniesAsync();
            products = await Api.GetProductsAsync();
            customers = await Api.GetCustomersAsync();
            sellers = await Api.GetSellersAsync();

            displayName =
                user.FindFirst(ClaimTypes.GivenName)?.Value ??
                user.FindFirst(ClaimTypes.Name)?.Value ??
                user.Identity?.Name;

            isAdmin = user.IsInRole(Roles.Admin);
            isSeller = user.IsInRole(Roles.Vendedor);

            sellerDisplayName = displayName;

            if (isSeller && !isAdmin)
            {
                request.IsSeller = true;
                sellerIdUi = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
                request.SellerId = sellerIdUi;
            }
            else
            {
                request.IsSeller = false;
                request.SellerId = null;
            }

            var cfg = await Api.GetConfigAsync();
            if (cfg is not null)
            {
                lossPercentUi = cfg.DefaultLossPercent;
                idealFreightUi = cfg.FreightIdealPercent;
                acceptableFreightUi = cfg.FreightAcceptablePercent;
            }

            await LoadRegionalsAsync();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            _loaded = true;
        }
    }

    private void AddItem()
        => request.Items.Add(new SimulationItemRequest { Quantity = 1 });

    private void RemoveItem(SimulationItemRequest item)
        => request.Items.Remove(item);

    private async Task OnSellerModeChanged(ChangeEventArgs e)
    {
        if (sellerModeLocked)
            return;

        var newValue = e.Value is bool b
            ? b
            : bool.TryParse(e.Value?.ToString(), out var parsed) && parsed;

        request.IsSeller = newValue;

        if (!request.IsSeller)
        {
            sellerIdUi = null;
            request.SellerId = null;
        }

        regionalIdUi = null;
        request.RegionalId = null;

        await LoadRegionalsAsync();
    }

    private async Task OnSellerChanged(ChangeEventArgs e)
    {
        sellerIdUi = e.Value?.ToString();
        request.SellerId = sellerIdUi;

        regionalIdUi = null;
        request.RegionalId = null;

        await LoadRegionalsAsync();
    }

    private Task OnRegionalChanged(ChangeEventArgs e)
    {
        regionalIdUi = e.Value?.ToString();

        request.RegionalId = Guid.TryParse(regionalIdUi, out var regionalGuid)
            ? regionalGuid
            : null;

        return Task.CompletedTask;
    }

    private async Task LoadRegionalsAsync()
    {
        if (request.IsSeller)
        {
            if (!string.IsNullOrWhiteSpace(sellerIdUi))
                regionals = await Api.GetRegionalsAsync(sellerIdUi);
            else
                regionals = new();
        }
        else
        {
            regionals = await Api.GetRegionalsAsync(null);
        }
    }

    private async Task RunSimulation()
    {
        isBusy = true;
        error = null;
        result = null;

        try
        {
            if (string.IsNullOrWhiteSpace(request.CustomerCode))
                throw new InvalidOperationException("Selecione o cliente.");

            if (string.IsNullOrWhiteSpace(request.CompanyBilling))
                throw new InvalidOperationException("Selecione a empresa de faturamento.");

            if (request.IsSeller && string.IsNullOrWhiteSpace(request.SellerId))
                throw new InvalidOperationException("Selecione o vendedor.");

            if (!request.RegionalId.HasValue)
                throw new InvalidOperationException("Selecione a regional.");

            if (request.Items.Count == 0)
                throw new InvalidOperationException("Adicione pelo menos um item.");

            foreach (var item in request.Items)
            {
                if (string.IsNullOrWhiteSpace(item.Sku))
                    throw new InvalidOperationException("Selecione um produto para todos os itens.");

                if (item.Quantity <= 0)
                    throw new InvalidOperationException("A quantidade deve ser maior que zero.");

                if (request.IsSeller && (!item.UnitPrice.HasValue || item.UnitPrice.Value <= 0))
                    throw new InvalidOperationException("Preço unitário é obrigatório para vendedor.");
            }

            request.Loss.LossPercent = request.IsPalletized ? null : lossPercentUi;

            // Mantidos por compatibilidade com o backend atual.
            request.Freight.IdealPercent = idealFreightUi;
            request.Freight.AcceptablePercent = acceptableFreightUi;

            var response = await Api.SimulateAsync(request);
            result = response?.Result;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task Logout()
    {
        await JS.InvokeVoidAsync("simuladorAuth.logout");
        Nav.NavigateTo("login", true);
    }
}